generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum Role {
  OWNER
  ADMIN
  USER
  FREELANCE
}

// Overarching model, Projects and Tasks are specifically created in a Team.
model Team {
  id                String             @id @default(cuid())
  name              String

  users             User[]            
  teamRoles         Role[]
  projects          Project[]
  tasks             Task[]

  dateCreated       DateTime           @default(now())
}


model User {
  id            String                 @id @default(cuid())
  name          String?
  email         String?                @unique
  emailVerified DateTime?
  accounts      Account[]

  password      String?
  role          Role               @default(USER)

  // These are needed for overview of personal projets and tasks a user is assigned to.
  projects      Project[]
  tasks         Task[]

  teamId        String?
  team          Team?                   @relation(fields: [teamId], references: [id], onDelete: SetNull)
}


enum PriorityType {
  LOW
  MEDIUM
  HIGH
}

enum StatusType {
    STARTING
    FINISHED
}


model Project {
    id          String          @default(cuid()) @id
    name        String

    managedBy   User?           @relation(fields: [managedById], references: [id], onDelete: SetNull)
    managedById String?

    startDate   DateTime        
    endDate     DateTime        

    priority    PriorityType    @default(LOW)
    status      StatusType
    budget      Int?            @default(0)
    archived    Boolean         @default(false)
    
    tasks       Task[]

    team        Team            @relation(fields: [teamId], references: [id], onDelete: Cascade)
    teamId      String
}

model Task {
  id          String            @default(cuid()) @id

  assignedTo   User?            @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  assignedToId String?
  dueDate      DateTime?

  taskName    String?           @default("")
  description String? 
  completed   Boolean           @default(false)

  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId   String 

  team        Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  teamId      String
}