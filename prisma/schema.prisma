generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]

}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  expires_in        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum Role {
  OWNER
  ADMIN
  USER
  FREELANCE
  OBSERVER
}

// Overarching model, Projects and Tasks are specifically created in a Team.
model Team {
  id          String    @id @default(cuid())
  name        String
  teamRoles   Role[]
  dateCreated DateTime  @default(now())
  projects    Project[]
  tasks       Task[]
  users       User[]
  tags        Tag[]
}

model User {
  id                String    @id @default(uuid())
  name              String    
  email             String   @unique
  emailVerified     DateTime?
  role              Role      @default(USER)

  accounts          Account[]
  tasks             Task[]
  
  teamId            String? 
  team              Team?     @relation(fields: [teamId], references: [id])
  preferredDateType String    @default("dd-MM-yyyy")

  projects          ProjectUser[]
  comments          Comment[]
  notifications     Notification[]
  favourites        Favourite[]

  @@index([teamId, id], map: "user_team_project_idx")
}


model VerificationToken {
  identifier String
  token      String
  expires    DateTime
 
  @@unique([identifier, token])
}

model CompanyInvitation {
  id        String      @default(cuid())
  email     String      @id
  name      String  
  role      Role
  teamId    String
  expiresAt DateTime @default(now())
}

model Project {
  id            String       @id @default(cuid())
  name          String
  description   String?
  startDate     DateTime
  endDate       DateTime
  priority      PriorityType @default(LOW)
  status        StatusType
  budget        Int         @default(0)
  archived      Boolean      @default(false)
  teamId        String

  team          Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Relation to ProjectUser for managing the many-to-many relationship
  users         ProjectUser[]
  tasks         Task[]
  tags          Tag[]
  expenses      Expense[]
  milestones    Milestone[]

  @@index([name, teamId], map: "name_team_idx")
  @@index([teamId, archived], map: "team_archived_idx")
}

// Join table to represent many-to-many relationship between Project and User
model ProjectUser {
    id          String     @default(cuid()) @id
    projectId   String
    userId      String
    isManager   Boolean    @default(false)

    project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([projectId, userId])  // Ensure a user can be assigned to a project only once
    @@index([projectId], map: "project_user_project_idx")
    @@index([userId], map: "project_user_user_idx")
}

model Milestone {
  id      String    @id @default(cuid())
  date    DateTime 
  title   String
  colors  String

  projectId  String?
  project    Project?  @relation(fields: [projectId], references: [id])
}

model Task {
  id           String         @id @default(cuid())
  taskCode     String

  type         TaskType @default(TASK)
  title        String
  description  String?
  priority     PriorityType   @default(LOW)
  status       TaskStatusType
  startDate    DateTime   @default(now())
  dueDate      DateTime   @default(now())

  // Allow for recursive subtasks
  parentId      String? // This field is null for top-level comments
  parent        Task?       @relation("SubTasks", fields: [parentId], references: [id])
  subtasks      Task[]      @relation("SubTasks")
 
  dateCreated  DateTime       @default(now())
  updatedAt    DateTime       @default(now()) @updatedAt

  assignedToId String?
  assignedTo   User?          @relation(fields: [assignedToId], references: [id])
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  teamId       String
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)
  tags         Tag[]
  comments     Comment[]
  
  @@index([projectId], map: "task_project_id_idx")
  @@index([assignedToId, teamId], map: "task_assignedTo_team_idx")  
}


enum TaskType {
  ISSUE
  STORY
  TASK
  TEST
  FEATURE
  EPIC
}

enum PriorityType {
  LOW
  MEDIUM
  HIGH
}

enum StatusType {
  ACTIVE
  CANCELLED
  ON_HOLD
  FINISHED
}

enum TaskStatusType {
  NEW 
  ACTIVE 
  DONE
}

model Tag {
  id           String   @id @default(cuid())
  title        String 

  teamId       String
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  project     Project[]
  tasks       Task[]
}

// Expense modelling
model Expense {
  id          String      @id @default(cuid())
  amount      Float
  title       String
  description String?
  date        DateTime  @default(now())
  
  expenseType ExpenseType
  
  // Relationships
  projectId   String?     // Nullable - expense may or may not be linked to a project
  project     Project? @relation(fields: [projectId], references: [id])

  updatedAt   DateTime @updatedAt
}

enum ExpenseType {
  LABOR       
  MATERIALS   
  SOFTWARE   
  TRAVEL       
  SERVICES  
  LICENSING 
  ADMINISTRATIVE
  MISC
}

model Comment {
  id        String      @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  // Relations
  taskId    String?
  task      Task?     @relation(fields: [taskId], references: [id])

  parentId  String? // This field is null for top-level comments
  parent    Comment? @relation("CommentReplies", fields: [parentId], references: [id])
  replies   Comment[] @relation("CommentReplies")

  // Author of the comment
  userId  String
  user    User      @relation(fields: [userId], references: [id])
}

model Notification {
  id    String    @id @default(cuid())
  userId          String?
  user            User?     @relation(fields: [userId], references: [id])

  sender          String
  title           String
  isRead          Boolean
  resourceId      String

  createdAt       DateTime  @default(now())
}

enum FavouriteType {
  PROJECT
  TASK
  ROUTE
}

model Favourite {
    id    String    @id @default(cuid())

    userId          String?
    user            User?     @relation(fields: [userId], references: [id])

    type            FavouriteType
    data            String
}