generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

generator zod {
  provider         = "npx zod-prisma-types"
  useMultipleFiles = true
  createInputTypes = false
  output           = "./zod"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// Overarching model, Projects and Tasks are specifically created in a Team.
model Team {
  id          String    @id @default(cuid())
  name        String
  teamRoles   Role[]
  dateCreated DateTime  @default(now())
  projects    Project[]
  tasks       Task[]
  users       User[]
  tags        Tag[]
}

model User {
  id                String    @id @default(cuid())
  name              String    
  email             String?   @unique
  emailVerified     DateTime?
  password          String?
  role              Role      @default(USER)
  teamId            String?
  accounts          Account[]
  // These are needed for overview of personal projets and tasks a user is assigned to.
  tasks             Task[]
  team              Team?     @relation(fields: [teamId], references: [id])
  preferredDateType String @default("dd-MM-yyyy")

  projects          ProjectUser[]  // Relation to ProjectUser for managing the many-to-many relationship
}

model VerificationToken {
  id      String   @id @default(uuid())
  email   String
  token   String   @unique
  expires DateTime

  @@unique([email, token])
}

model Project {
  id          String       @id @default(cuid())
  name        String
  startDate   DateTime
  endDate     DateTime
  priority    PriorityType @default(LOW)
  status      StatusType
  budget      Int?         @default(0)
  archived    Boolean      @default(false)
  teamId      String

  team        Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  // Relation to ProjectUser for managing the many-to-many relationship
  users       ProjectUser[]
  tasks       Task[]
  tag         Tag[]

  // Task categories are defined at project level. 
  taskCategories  TaskCategory[]
}

model Task {
  id           String         @id @default(cuid())
  taskCode     String

  title        String
  description  String?
  priority     PriorityType   @default(LOW)
  status       TaskStatusType
  dueDate      DateTime?

  // We allow tasks to be of optional category type.
  categoryId    String?
  category      TaskCategory? @relation(fields: [categoryId], references: [id])
 
  dateCreated  DateTime       @default(now())
  lastUpdated  DateTime       @default(now())

  assignedToId String?
  assignedTo   User?          @relation(fields: [assignedToId], references: [id])
  
  projectId    String
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  teamId       String
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  tags          Tag[]
}

model TaskCategory {
  id    String    @id @default(cuid())
  title String
  icon  String // Storing the identifier/name of the Lucide icon

  projectId   String
  project     Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  task Task[]
}

model Status {
  id          String    @id @default(cuid())
  statusType  String
}

enum Role {
  OWNER
  ADMIN
  USER
  FREELANCE
}

enum PriorityType {
  LOW
  MEDIUM
  HIGH
}

enum StatusType {
  NOTSTARTED
  ONHOLD
  ONGOING
  FINISHED
}

enum TaskStatusType {
  TODO
  DOING
  INREVIEW
  DONE
}

// Join table to represent many-to-many relationship between Project and User
model ProjectUser {
    id          String     @default(cuid()) @id
    projectId   String
    userId      String
    isManager   Boolean    @default(false)

    project     Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
    user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)

    @@unique([projectId, userId])  // Ensure a user can be assigned to a project only once
}

model Tag {
  id           String   @id @default(cuid())
  title        String 

  teamId       String
  team         Team           @relation(fields: [teamId], references: [id], onDelete: Cascade)

  projectId   String?
  project     Project?           @relation(fields: [projectId], references: [id], onDelete: Cascade)

  taskId   String?
  task     Task?           @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

