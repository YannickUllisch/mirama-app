generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-arm64-openssl-3.0.x", "linux-arm64-openssl-1.1.x", "rhel-openssl-3.0.x", "rhel-openssl-1.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}


// ### IDENTITY & BILLING AGGREGATES ###
model Tenant {
  id String @id @default(cuid())
  adminUserId          String

  organizations Organization[]

  userId String @unique
  user   User   @relation(name: "UserToTenant", fields: [userId], references: [id])

  subscription Subscription?
  settings     TenantSettings?
  usageMetrics UsageMetric[]
}

model User {
  id            String     @id @default(uuid())

  name          String
  email         String     @unique
  emailVerified DateTime?
  image         String?
  role          TenantRole @default(USER)

  tenant       Tenant?       @relation("UserToTenant")
  accounts     Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  expires_in        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

enum TenantRole {
  OWNER
  ADMIN
  USER
}

// Subscription model on Tenant
model Subscription {
  id                 String             @id @default(cuid())
  tenantId           String             @unique
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  planId             String
  plan               Plan               @relation(fields: [planId], references: [id])
  
  status             SubscriptionStatus @default(TRIALING)
  stripeSubscriptionId String?          @unique
  periodStart        DateTime
  periodEnd          DateTime
  cancelAtPeriodEnd  Boolean            @default(false)
}

model Plan {
  id            String         @id @default(cuid())
  name          String         // e.g., "Pro", "Enterprise"
  description   String?
  price         Int            // In cents
  interval      String         // "month" or "year"
  features      Json           // Store flags like { "maxUsers": 10, "apiAccess": true }
  subscriptions Subscription[]
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  CANCELED
  PAST_DUE
  UNPAID
}

model TenantSettings {
  id        String  @id @default(cuid())
  tenantId  String  @unique
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  timezone  String  @default("UTC")

  brandingColor        String?
  logoUrl              String?
  receiveNotifications Boolean @default(true)

  name                 String
  isActive             Boolean
}

model UsageMetric {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  type      String   // e.g., "API_CALLS", "STORAGE_MB"
  value     Int
  recordedAt DateTime @default(now())

  @@index([tenantId, type])
}


// ### ORGANIZATION AGGREGATE ROOT SECTION ###
model Organization {
  id String @id @default(cuid())

  tenantId    String
  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  name        String
  slug        String
  street      String
  city        String
  state       String
  zipCode     String
  dateCreated DateTime @default(now())

  projects    Project[]
  invitations OrganizationInvitation[]
  tasks       Task[]
  members     Member[]
  teams       Team[]
  tags        Tag[]
}

enum OrganizationRole {
  OWNER
  ADMIN
  USER
  FREELANCE
  CLIENT
}

model Team {
  id          String   @id @default(cuid())
  name        String
  slug        String
  members     Member[]
  dateCreated DateTime @default(now())

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
}

model Member {
  id            String           @id @default(uuid())
  name          String
  email         String

  role          OrganizationRole @default(USER)

  tasks    Task[]
  teams    Team[]

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  projectLinks  ProjectMember[]
  comments      Comment[]
  notifications Notification[]
  favourites    Favourite[]

  @@index([organizationId, id], map: "member_organization_project_idx")
}

model OrganizationInvitation {
  id String @default(cuid())

  email     String           @id
  name      String
  role      OrganizationRole
  inviterId String
  status    InvitationStatus @default(PENDING)

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  expiresAt      DateTime     @default(now())
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model Tag {
  id    String @id @default(cuid())
  title String

  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  project Project[]
  tasks   Task[]
}

// ### PROJECT AGGREGATE ROOT SECTION ###
model Project {
  id             String       @id @default(cuid())
  name           String
  description    String?
  startDate      DateTime
  endDate        DateTime
  priority       PriorityType @default(LOW)
  status         StatusType
  budget         Int          @default(0)
  archived       Boolean      @default(false)
  
  organizationId String
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  // Relation to ProjectUser for managing the many-to-many relationship
  members    ProjectMember[]
  tasks      Task[]
  tags       Tag[]
  expenses   Expense[]
  milestones Milestone[]

  @@index([name, organizationId], map: "name_organization_idx")
  @@index([organizationId, archived], map: "team_archived_idx")
}

// Join table to represent many-to-many relationship between Project and User
model ProjectMember {
  id        String  @id @default(cuid())
  isManager Boolean @default(false)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  member   Member @relation(fields: [memberId], references: [id])
  memberId String

  @@unique([projectId, memberId])
  @@index([projectId], map: "project_user_project_idx")
  @@index([memberId], map: "project_member_idx")
}

model Milestone {
  id     String   @id @default(cuid())
  date   DateTime
  title  String
  colors String

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum PriorityType {
  LOW
  MEDIUM
  HIGH
}

enum StatusType {
  ACTIVE
  CANCELLED
  ON_HOLD
  FINISHED
}

// ### TASK AGGREGATE ROOT SECTION ###
model Task {
  id       String @id @default(cuid())
  taskCode String

  type        TaskType       @default(TASK)
  title       String
  description String?
  priority    PriorityType   @default(LOW)
  status      TaskStatusType
  startDate   DateTime       @default(now())
  dueDate     DateTime       @default(now())

  // Allow for recursive subtasks
  parentId String? // This field is null for top-level comments
  parent   Task?   @relation("SubTasks", fields: [parentId], references: [id])
  subtasks Task[]  @relation("SubTasks")

  dateCreated DateTime @default(now())
  updatedAt   DateTime @default(now()) @updatedAt

  assignedToId   String?
  assignedTo     Member?      @relation(fields: [assignedToId], references: [id])
  projectId      String
  project        Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tags           Tag[]
  comments       Comment[]

  @@index([projectId], map: "task_project_id_idx")
  @@index([assignedToId, organizationId], map: "task_assignedTo_organization_idx")
}

enum TaskType {
  ISSUE
  STORY
  TASK
  TEST
  FEATURE
  EPIC
}

enum TaskStatusType {
  NEW
  ACTIVE
  DONE
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now())

  // Relations
  taskId String?
  task   Task?   @relation(fields: [taskId], references: [id])

  parentId String? // This field is null for top-level comments
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  // Author of the comment
  memberId String
  member   Member @relation(fields: [memberId], references: [id])
}

// ### EXPENSE AGGREGATE ROOT SECTION ###
model Expense {
  id          String   @id @default(cuid())
  amount      Float
  title       String
  description String?
  date        DateTime @default(now())

  expenseType ExpenseType

  // Relationships
  projectId String? // Nullable - expense may or may not be linked to a project
  project   Project? @relation(fields: [projectId], references: [id])

  updatedAt DateTime @updatedAt
}

enum ExpenseType {
  LABOR
  MATERIALS
  SOFTWARE
  TRAVEL
  SERVICES
  LICENSING
  ADMINISTRATIVE
  MISC
}

// ### NOTIFICATION AGGREGATE ROOT SECTION ###
model Notification {
  id String @id @default(cuid())

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  sender     String
  title      String
  isRead     Boolean
  resourceId String

  createdAt DateTime @default(now())
}

// ### FAVOURITE AGGREGATE ROOT SECTION ###
model Favourite {
  id String @id @default(cuid())

  memberId String?
  member   Member? @relation(fields: [memberId], references: [id])

  type FavouriteType
  data String
}

enum FavouriteType {
  PROJECT
  TASK
  ROUTE
}

// ### OTHER MODELS ###
model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
}

model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  userId    String?
  action    String   // TODO: "USER_INVITED", "BILLING_CHANGED" and so on
  entity    String
  entityId  String
  metadata  Json
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}