{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "es2022"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "ESNext",
    "target": "ES2022",
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@auth": ["./server/auth/auth.ts"],
      "@db": ["./server/utils/db.ts"],
      "@scopedDb": ["./serverNew/shared/infrastructure/scoped-db.ts"],
      "@authMiddleware": ["./serverNew/middleware/withAuth.ts"],
      "@api": ["./src/lib/api.ts"],
      "@logger": ["./server/utils/logger.ts"],
      "@withAuth": ["./server/auth/withAuth.ts"],
      "@server/*": ["./server/*"],
      "@hooks/*": ["./src/hooks/*"],
      "@services/*": ["./src/services/*"],
      "@ui/*": ["./src/components/ui/*"],
      "@public/*": ["./public/*"],
      "@src/*": ["./src/*"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    "commitlint.config.ts",
    "src/types/**/*",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
